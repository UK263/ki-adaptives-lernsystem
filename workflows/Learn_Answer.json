            },
            {
              "content": "=Bewerte diese Antwort:\n\nFrage: {{ $json.question_text }}\nOptionen: {{ $json.options }}\nUser-Antwort: {{ $json.user_answer }}\nRichtige Antwort: {{ $json.correct_answer }}\nErklärung: {{ $json.explanation }}\n\nAntwort als JSON:\n{\"is_correct\":true,\"user_answer\":\"gewählte Option\",\"correct_answer\":\"richtige Option\",\"question_text\":\"die Frage\",\"explanation\":\"2-3 Sätze Erklärung\",\"example\":\"Praxisbeispiel\",\"quality\":4}\n\nquality: 5=perfekt 4=richtig 3=knapp 2=falsch+klar 1=falsch+unklar 0=falsch\nis_correct=true wenn User-Zahl zur richtigen Option passt."
            }
          ]
