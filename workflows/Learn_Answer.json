    {
      "parameters": {
        "jsCode": "const sm2 = $('SM2 + History').first().json;\nconst s = $('Get User Stats').all();\nconst sp = s.length > 0 ? s[0].json : {};\n\nconst oldT = parseInt(sp.property_total_answered || sp.total_answered) || 0;\nconst oldC = parseInt(sp.property_total_correct || sp.total_correct) || 0;\nconst oldS = parseInt(sp.property_current_streak || sp.current_streak) || 0;\n\nconst newT = oldT + 1;\nconst newC = sm2.is_correct ? oldC + 1 : oldC;\nconst newS = sm2.is_correct ? oldS + 1 : 0;\nconst newA = newT > 0 ? Math.round((newC / newT) * 100) : 0;\n\nreturn [{ json: {\n  stats_id: s.length > 0 ? s[0].json.id : '',\n  total_answered: newT,\n  total_correct: newC,\n  current_streak: newS,\n  accuracy_percent: newA,\n  last_activity: new Date().toISOString()\n}}];\n"
