    {
      "parameters": {
        "jsCode": "// KERN-NODE: GPT parsen + History finden + SM-2 berechnen\n// Liest von: GPT Bewertung, Match Frage, Get Question History\n\n// 1. GPT Output parsen\nconst gptNode = $('GPT Bewertung').first().json;\nconst gptRaw = gptNode.message?.content || gptNode.text || '';\nconst cleaned = gptRaw.replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\nlet gpt = {};\ntry { gpt = JSON.parse(cleaned); }\ncatch(e) {\n  // Fallback: versuche Teilstring zu parsen\n  const jsonMatch = cleaned.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    try { gpt = JSON.parse(jsonMatch[0]); } catch(e2) {}\n  }\n  if (!gpt.is_correct && gpt.is_correct !== false) {\n    throw new Error('GPT Parse Error: ' + e.message + ' | Output: ' + cleaned.substring(0, 200));\n  }\n}\n\n// 2. Match-Daten\nconst match = $('Match Frage').first().json;\nconst isCorrect = gpt.is_correct === true;\nconst quality = parseInt(gpt.quality) || (isCorrect ? 4 : 1);\n\n// 3. History per page_id suchen\nlet historyId = '';\nlet h = null;\ntry {\n  const historyItems = $('Get Question History').all();\n  for (const item of historyItems) {\n    const pid = (item.json.property_page_id || item.json.page_id || '').toString().trim();\n    if (pid && pid === match.page_id) {\n      historyId = item.json.id;\n      h = item.json;\n      break;\n    }\n  }\n} catch(e) {\n  // History nicht geladen? Kein Problem, erstellen wir neu\n}\n\n// Helper\nfunction gp(obj, name) {\n  if (!obj) return null;\n  const v1 = obj['property_' + name];\n  if (v1 != null && v1 !== '') return v1;\n  const v2 = obj[name];\n  if (v2 != null && v2 !== '') return v2;\n  return null;\n}\n\n// 4. SM-2 Berechnung\nlet ef = h ? (parseFloat(gp(h, 'ease_factor')) || 2.5) : 2.5;\nlet interval = h ? (parseInt(gp(h, 'interval')) || 0) : 0;\nlet reps = h ? (parseInt(gp(h, 'repetitions')) || 0) : 0;\nlet tc = h ? (parseInt(gp(h, 'times_correct')) || 0) : 0;\nlet ti = h ? (parseInt(gp(h, 'times_incorrect')) || 0) : 0;\n\nif (isCorrect) {\n  tc++; reps++;\n  if (reps === 1) interval = 1;\n  else if (reps === 2) interval = 6;\n  else interval = Math.round(interval * ef);\n} else {\n  ti++; reps = 0; interval = 0;\n}\n\nef = ef + (0.1 - (5 - quality) * (0.08 + (5 - quality) * 0.02));\nif (ef < 1.3) ef = 1.3;\nef = Math.round(ef * 100) / 100;\n\nconst nextDue = new Date();\nnextDue.setDate(nextDue.getDate() + Math.max(interval, 1));\nconst total = tc + ti;\nconst accuracy = total > 0 ? Math.round((tc / total) * 100) : 0;\n\nconst srMsg = isCorrect\n  ? (interval <= 1 ? '📅 Morgen wieder' : '📅 In ' + interval + ' Tagen wieder')\n  : '🔄 Bald wiederholt';\n\nreturn [{ json: {\n  is_correct: isCorrect,\n  user_answer: gpt.user_answer || match.user_answer,\n  correct_answer: gpt.correct_answer || match.correct_answer,\n  question_text: gpt.question_text || match.question_text,\n  explanation: gpt.explanation || match.explanation || '',\n  example: gpt.example || '',\n  sr_message: srMsg,\n  accuracy_percent: accuracy,\n  times_correct: tc,\n  times_incorrect: ti,\n  ease_factor: ef,\n  interval: interval,\n  repetitions: reps,\n  next_due: nextDue.toISOString(),\n  page_id: match.page_id || '',\n  subject: match.subject || '',\n  question_id: match.question_id || '',\n  answered_at: match.answered_at,\n  chat_id: match.chat_id,\n  history_id: historyId,\n  history_exists: historyId !== ''\n}}];\n"
      },
