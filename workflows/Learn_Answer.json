      "parameters": {
        "jsCode": "// SCHRITT 1: Match Telegram-Reply zu Active_Question\nconst trigger = $('Telegram Trigger').first().json;\nconst msg = trigger.message || trigger;\nconst userText = (msg.text || '').trim();\nconst replyTo = msg.reply_to_message?.message_id;\n\nif (!replyTo) {\n  return [{ json: { error: true, error_message: '❌ Bitte antworte direkt auf eine Quiz-Frage.' }}];\n}\n\nconst replyId = replyTo.toString();\nconst activeItems = $('Get Active_Questions').all();\n\nfor (const item of activeItems) {\n  const mid = (item.json.property_telegram_message_id || '').toString().trim();\n  if (!mid || mid !== replyId) continue;\n\n  return [{ json: {\n    error: false,\n    user_answer: userText,\n    answered_at: new Date().toISOString(),\n    chat_id: (msg.chat?.id || 'YOUR_TELEGRAM_CHAT_ID').toString(),\n    question_text: item.json.name || '',\n    notion_page_id: item.json.id || '',\n    question_id: item.json.property_question_id || '',\n    correct_answer: item.json.property_correct_answer || '',\n    explanation: item.json.property_explanation || '',\n    subject: item.json.property_subject || '',\n    difficulty: item.json.property_difficulty || '',\n    options: item.json.property_options || '',\n    page_id: item.json.property_page_id || ''\n  }}];\n}\n\nreturn [{ json: { error: true, error_message: '❌ Frage nicht gefunden. Starte ein neues Quiz!' }}];\n"
      },
